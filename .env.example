# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate strong secrets: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
SESSION_SECRET="your-session-secret-at-least-32-chars-long-change-this"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Sampadaa"

# ─── Email Notifications (Optional — uses free Gmail SMTP) ───────────────────
# Setup: Google Account → Security → App Passwords → Generate
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-16-char-app-password"
# SMTP_FROM="Sampadaa <your-email@gmail.com>"

# ─── Cron Security (Optional) ─────────────────────────────────────────────────
# Protects the /api/cron/overdue-check endpoint
# CRON_SECRET="your-cron-secret-key"
