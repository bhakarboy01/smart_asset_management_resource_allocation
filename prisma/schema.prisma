// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Models ────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  role          String    @default("USER")
  rollNumber    String?   @unique
  department    String?
  phone         String?
  avatar        String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  bookings      Booking[]
  auditLogs     AuditLog[]
  notifications Notification[]

  @@map("users")
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  icon        String?
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assets      Asset[]

  @@map("categories")
}

model Asset {
  id              String         @id @default(cuid())
  name            String
  description     String?
  categoryId      String
  totalQuantity   Int            @default(1)
  availableQty    Int            @default(1)
  status          String         @default("AVAILABLE")
  condition       String         @default("GOOD")
  location        String?
  serialNumber    String?        @unique
  purchaseDate    DateTime?
  purchasePrice   Float?
  warrantyExpiry  DateTime?
  imageUrl        String?
  qrCode          String?
  notes           String?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  category        Category       @relation(fields: [categoryId], references: [id])
  bookings        Booking[]
  maintenanceLogs MaintenanceLog[]

  @@map("assets")
}

model Booking {
  id             String        @id @default(cuid())
  userId         String
  assetId        String
  quantity       Int           @default(1)
  purpose        String
  eventName      String?
  fromDate       DateTime
  toDate         DateTime
  issuedAt       DateTime?
  returnedAt     DateTime?
  status         String        @default("PENDING")
  adminNotes     String?
  rejectionReason String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user           User          @relation(fields: [userId], references: [id])
  asset          Asset         @relation(fields: [assetId], references: [id])

  @@map("bookings")
}

model MaintenanceLog {
  id          String         @id @default(cuid())
  assetId     String
  title       String
  description String?
  condition   String
  cost        Float?
  technicianName String?
  scheduledAt DateTime?
  completedAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  asset       Asset          @relation(fields: [assetId], references: [id])

  @@map("maintenance_logs")
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  action     String
  entityType String?
  entityId   String?
  details    String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime    @default(now())

  user       User?       @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@map("notifications")
}
